# Database
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/dekker_group

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-string
JWT_REFRESH_SECRET=change-this-to-a-different-long-random-secret-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Email (configure when ready)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@dekkergroup.co.nz

# ArcSite integration (https://api.arcsite.com/v1)
ARCSITE_API_TOKEN=
ARCSITE_OWNER_EMAIL=sales@dekkergroup.co.nz

# Xero integration (OAuth2 — developer.xero.com)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:3001/api/xero/callback
# Set after registering the webhook URL in the Xero developer portal — the
# webhook receiver rejects all requests (401) until this is configured.
XERO_WEBHOOK_KEY=
